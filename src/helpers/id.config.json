{
  "card": {
    "name": "KYCHEW ID Card",
    "organization": "Katsina State Young Community Health Extension Workers",
    "abbreviation": "KYCHEW",
    "dimensions": {
      "width": 638,
      "height": 1011,
      "unit": "px",
      "aspectRatio": "CR80-portrait",
      "physicalSize": {
        "width": 85.60,
        "height": 53.98,
        "unit": "mm"
      }
    },
    "colorPalette": {
      "primaryGreen": "#1B5E3B",
      "accentGreen": "#2E7D52",
      "lightGreen": "#4CAF70",
      "badgeGreen": "#3CB371",
      "white": "#FFFFFF",
      "offWhite": "#F5F5F5",
      "black": "#000000",
      "darkText": "#111111",
      "watermarkGray": "rgba(180, 180, 180, 0.15)"
    }
  },

  "front": {
    "background": {
      "type": "image",
      "src": "/assets/front.png",
      "position": {
        "x": 0,
        "y": 0,
        "width": "100%",
        "height": "100%"
      },
      "objectFit": "cover"
    },

    "photoFrame": {
      "id": "member_photo_frame",
      "type": "hexagon",
      "position": {
        "x": 169,
        "y": 115,
        "width": 300,
        "height": 300
      },
      "borderColor": "#3CB371",
      "borderWidth": 8,
      "background": "#E0E0E0",
      "clipShape": "hexagon"
    },

    "memberPhoto": {
      "id": "member_photo",
      "type": "image",
      "src": "{{memberPhotoUrl}}",
      "position": {
        "x": 177,
        "y": 123,
        "width": 284,
        "height": 284
      },
      "clipShape": "hexagon",
      "objectFit": "cover"
    },

    "memberName": {
      "id": "member_name",
      "type": "text",
      "text": "{{memberName}}",
      "position": {
        "x": "center",
        "y": 530
      },
      "font": {
        "family": "Montserrat",
        "fallback": "Arial, sans-serif",
        "size": 35,
        "weight": "700",
        "style": "normal",
        "letterSpacing": 0.3
      },
      "color": "#111111",
      "align": "center",
      "maxWidth": 580
    },

    "roleBadge": {
      "id": "role_badge",
      "type": "badge",
      "position": {
        "x": "center",
        "y": 800,
        "width": 220,
        "height": 36
      },
      "background": "#3CB371",
      "borderRadius": 18,
      "text": {
        "content": "{{memberRole}}",
        "font": {
          "family": "Montserrat",
          "fallback": "Arial, sans-serif",
          "size": 16,
          "weight": "600",
          "style": "italic",
          "letterSpacing": 1.5
        },
        "color": "#FFFFFF",
        "align": "center",
        "textTransform": "uppercase"
      }
    },

    "details": {
      "id": "member_details",
      "type": "fieldGroup",
      "position": {
        "x": 70,
        "y": 440
      },
      "rowHeight": 48,
      "labelFont": {
        "family": "Montserrat",
        "fallback": "Arial, sans-serif",
        "size": 18,
        "weight": "700",
        "style": "normal"
      },
      "valueFont": {
        "family": "Montserrat",
        "fallback": "Arial, sans-serif",
        "size": 18,
        "weight": "400",
        "style": "normal"
      },
      "color": "#111111",
      "fields": [
        {
          "id": "field_phone",
          "label": "Phone:",
          "labelX": 50,
          "valueX": 175,
          "y": 546,
          "value": "{{memberPhone}}"
        },
        {
          "id": "field_regNo",
          "label": "Reg No:",
          "labelX": 50,
          "valueX": 175,
          "y": 594,
          "value": "{{memberRegNo}}"
        },
        {
          "id": "field_lga",
          "label": "L.G.A :",
          "labelX": 50,
          "valueX": 175,
          "y": 642,
          "value": "{{memberLGA}}"
        }
      ]
    },

    "barcode": {
      "id": "member_barcode",
      "type": "barcode",
      "format": "QR",
      "data": "{{memberRegNo}}",
      "position": {
        "x": 100,
        "y": 85,
        "width": 150,
        "height": 150
      },
      "colors": {
        "dark": "#000000",
        "light": "#FFFFFF"
      },
      "errorCorrectionLevel": "M"
    }
  },

  "back": {
    "background": {
      "type": "image",
      "src": "/assets/back.png",
      "position": {
        "x": 0,
        "y": 0,
        "width": "100%",
        "height": "100%"
      },
      "objectFit": "cover"
    },

    "dates": {
      "id": "dates_section",
      "type": "dateGroup",
      "position": {
        "y": 660
      },
      "separatorLine": {
        "enabled": true,
        "y": 656,
        "color": "#111111",
        "thickness": 1.5
      },
      "issueDate": {
        "id": "issue_date",
        "labelText": "Issue Date",
        "valueText": "{{issueDate}}",
        "position": {
          "x": 50,
          "y": 660
        },
        "valueFont": {
          "family": "Montserrat",
          "fallback": "Arial, sans-serif",
          "size": 20,
          "weight": "700",
          "style": "normal",
          "textDecoration": "underline"
        },
        "labelFont": {
          "family": "Montserrat",
          "fallback": "Arial, sans-serif",
          "size": 18,
          "weight": "700",
          "style": "normal"
        },
        "color": "#2a6445",
        "labelY": 694
      },
      "expiredDate": {
        "id": "expired_date",
        "labelText": "Expired Date",
        "valueText": "{{expiredDate}}",
        "position": {
          "x": "right",
          "marginRight": 50,
          "y": 660
        },
        "valueFont": {
          "family": "Montserrat",
          "fallback": "Arial, sans-serif",
          "size": 20,
          "weight": "700",
          "style": "normal",
          "textDecoration": "underline"
        },
        "labelFont": {
          "family": "Montserrat",
          "fallback": "Arial, sans-serif",
          "size": 18,
          "weight": "700",
          "style": "normal"
        },
        "color": "#2a6445",
        "align": "right",
        "labelY": 694
      }
    }
  },

  "templateVariables": {
    "memberName": {
      "type": "string",
      "description": "Full name of the member",
      "example": "Aliyu Sada Maiwada",
      "required": true
    },
    "memberRole": {
      "type": "string",
      "description": "Role/title of the member",
      "example": "PRACTITIONER",
      "required": true,
      "options": ["PRACTITIONER", "COORDINATOR", "SUPERVISOR", "DIRECTOR", "VOLUNTEER"]
    },
    "memberPhone": {
      "type": "string",
      "description": "Contact phone number",
      "example": "08065550000",
      "required": true
    },
    "memberRegNo": {
      "type": "string",
      "description": "Registration number",
      "example": "KYCHEW-2026-0225",
      "pattern": "KYCHEW-YYYY-NNNN",
      "required": true
    },
    "memberLGA": {
      "type": "string",
      "description": "Local Government Area",
      "example": "Katsina",
      "required": true
    },
    "memberPhotoUrl": {
      "type": "string",
      "description": "URL or base64 of member passport photo",
      "example": "assets/photos/member_001.jpg",
      "required": true
    },
    "issueDate": {
      "type": "string",
      "description": "Date card was issued (DD-MM-YYYY)",
      "example": "20-02-2024",
      "required": true
    },
    "expiredDate": {
      "type": "string",
      "description": "Date card expires (DD-MM-YYYY)",
      "example": "20-02-2026",
      "required": true
    }
  },

  "fonts": {
    "primary": {
      "family": "Montserrat",
      "weights": [400, 600, 700, 800],
      "styles": ["normal", "italic"],
      "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,600;0,700;0,800;1,600&display=swap"
    },
    "secondary": {
      "family": "Times New Roman",
      "weights": [700],
      "styles": ["italic"],
      "note": "System font, no import needed"
    }
  },

  "printSettings": {
    "bleed": 3,
    "safeZone": 8,
    "resolution": 300,
    "colorSpace": "CMYK",
    "format": "PDF"
  }
}